{
  "name": "peixaria-khrismir",
  "productName": "Peixaria Khrismir",
  "private": true,
  "version": "1.5.0",
  "description": "Sistema de Gestão de Peixaria",
  "author": "Khrismir",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --config vite.config.web.ts",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "vite build && node build-app.mjs",
    "electron:pack": "node build-app.mjs",
    "deploy:web": "npm run build:web && npx vercel deploy --prod --yes",
    "deploy:all": "node deploy-all.mjs"
  },
  "build": {
    "appId": "ao.khrismir.peixaria",
    "productName": "Peixaria Khrismir",
    "copyright": "© 2025 Khrismir",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Peixaria Khrismir",
      "installerLanguages": ["pt_PT"],
      "language": "2070"
    },
    "portable": {
      "artifactName": "PeixariaKhrismir-Portatil-${version}.exe"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "supabase": "^2.98.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
